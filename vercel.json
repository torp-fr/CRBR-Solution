{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/js/db.js",         "destination": "/js/db.js" },
    { "source": "/js/engine.js",     "destination": "/js/engine.js" },
    { "source": "/js/app.js",        "destination": "/js/app.js" },
    { "source": "/js/views/:path*",  "destination": "/js/views/:path*" },
    { "source": "/css/:path*",       "destination": "/css/:path*" },
    { "source": "/img/:path*",       "destination": "/img/:path*" },
    { "source": "/:path*",           "destination": "/vitrine/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
